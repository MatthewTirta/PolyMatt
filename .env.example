# Polymarket CLOB API
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws

# Wallet — only needed for live manual trading, leave blank for paper trading
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Telegram — get BOT_TOKEN from @BotFather, CHAT_ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub — needed for scripts/reschedule.py
GITHUB_TOKEN=
GITHUB_REPO=YOUR_USERNAME/PolyMatt

# Risk controls
MAX_RISK_PER_TRADE_PCT=2
MAX_DAILY_LOSS_PCT=10
MAX_CONCURRENT_POSITIONS=3
MIN_LIQUIDITY_USD=500
MAX_SPREAD_PCT=5
COOLDOWN_AFTER_LOSSES_MIN=10
KILL_SWITCH=false

# Paper trading
PAPER_BANKROLL_USD=1000

# Logging
LOG_LEVEL=INFO
